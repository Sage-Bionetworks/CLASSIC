        "CohortPopulation": {
            "additionalProperties": false,
            "description": "Tier 3 record \u2014 cohort definition, demographics, and eligibility.",
            "properties": {
                "GUID": {
                    "description": "Global Unique Identifier: unique across studies and repositories. If a participant has been assigned a global identifier (e.g., NDAR GUID), include it here to support linkage across studies and repositories. Otherwise, leave this field blank.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "ageGroup": {
                    "$ref": "#/$defs/AgeGroupEnum",
                    "description": "Broad age-based population grouping represented in the cohort."
                },
                "aggregationLevel": {
                    "$ref": "#/$defs/AggregationLevelEnum",
                    "description": "Specifies whether a metadata value represents individual-level data or an aggregate summary."
                },
                "appliesTo": {
                    "$ref": "#/$defs/AppliesToEnum",
                    "description": "Indicates the level of entity to which a metadata value applies (e.g., individual participant or population summary)."
                },
                "ascertainmentContext": {
                    "$ref": "#/$defs/AscertainmentContextEnum",
                    "description": "Where participants came from: the categories describe sampling context, independent of disease focus."
                },
                "constructDomain": {
                    "$ref": "#/$defs/ConstructDomainEnum",
                    "description": "Domain of measured construct."
                },
                "criteriaSelectionIntensity": {
                    "$ref": "#/$defs/CriteriaSelectionIntensityEnum",
                    "description": "Overall restrictiveness of inclusion/exclusion criteria."
                },
                "diseaseFocus": {
                    "$ref": "#/$defs/DiseaseFocusEnum",
                    "description": "Primary disease or condition focus of the study. A categorical descriptor summarizing participant health status selection and ascertainment context for a study cohort, intended to support discovery and comparison across studies."
                },
                "eligibilityCriteriaSummary": {
                    "description": "A brief summary of the major inclusion and exclusion criteria that determined who could enroll in the study/cohort.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "eligibilityCriteriaURL": {
                    "description": "Link to the protocol, registry record, or document containing full inclusion/exclusion criteria.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "ethnicity": {
                    "$ref": "#/$defs/EthnicityEnum",
                    "description": "Self-reported race/ethnicity. A self-identified cultural classification that reflects whether a participant identifies as being of Hispanic or Latino origin, independent of race."
                },
                "ethnicityDistribution": {
                    "description": "A summary of the proportion or count of participants in a population by self-identified ethnicity.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "exclusionTags": {
                    "$ref": "#/$defs/ExclusionTagsEnum",
                    "description": "High-level exclusion characteristics used to restrict enrollment."
                },
                "externalParticipantID": {
                    "description": "Other external identifier, if no GUID exists.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "gender": {
                    "$ref": "#/$defs/GenderEnum",
                    "description": "The socially and culturally constructed identity that describes a person's self-identified gender, which may or may not correspond to sex assigned at birth and may change over time."
                },
                "genderDistribution": {
                    "description": "A summary of the proportion or count of participants in a population by self-identified gender.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "generation": {
                    "$ref": "#/$defs/GenerationEnum",
                    "description": "Generation within family cohort (ex., F0=original, F1=child, F2=grandchild). Indicates the generational position of participants within a family-based cohort, relative to the originally enrolled participant(s)."
                },
                "inclusionTags": {
                    "$ref": "#/$defs/InclusionTagsEnum",
                    "description": "High-level inclusion characteristics used to define the enrolled population."
                },
                "optional_row_identifier": {
                    "$ref": "#/$defs/PersistentRowIdentifierEnum",
                    "description": "Use studyID as the anchor, plus a persistent row identifier to identify a specific file/version, etc."
                },
                "optional_row_identifier_value": {
                    "description": "Enter a unique identifier for the selection made.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "populationDescriptor": {
                    "description": "Free-text descriptor capturing key population characteristics not covered by controlled terms (e.g., \"male veterans\", \"older adults with caregiver support\").",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "populationScope": {
                    "$ref": "#/$defs/PopulationScopeEnum",
                    "description": "Identifies the population described by the metadata (e.g., study-wide, cohort, or study arm)."
                },
                "populationType": {
                    "$ref": "#/$defs/PopulationTypeEnum",
                    "description": "Broad classification of the population sampled in the study/cohort."
                },
                "primaryHealthFocus": {
                    "$ref": "#/$defs/PrimaryHealthFocusEnum",
                    "description": "Why participants were included: these categories describe participant health status at enrollment, not outcomes."
                },
                "race": {
                    "$ref": "#/$defs/RaceEnum",
                    "description": "Self-reported race/ethnicity. A socially defined classification that reflects a participant's self-identified racial group(s), based on shared social, historical, or cultural experiences, and not biological or genetic differences."
                },
                "raceDistribution": {
                    "description": "A summary of the proportion or count of participants in a population by self-identified race category or categories.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "relationToOriginal": {
                    "$ref": "#/$defs/RelationToOriginalEnum",
                    "description": "Relationship to original participant (ex., self, child, grandchild, spouse). Describes the familial relationship(s) of participants to the initially enrolled participant(s) in a family-based cohort."
                },
                "selectionIntensity": {
                    "$ref": "#/$defs/SelectionIntensityEnum",
                    "description": "How restrictive enrollment was: the categories describe selection methodology."
                },
                "sex": {
                    "$ref": "#/$defs/SexEnum",
                    "description": "The biological classification of a participant, typically assigned at birth based on physical and genetic characteristics."
                },
                "sexDistribution": {
                    "description": "A summary of the proportion or count of participants in a population by sex category.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "sexEligible": {
                    "$ref": "#/$defs/SexEligibleEnum",
                    "description": "Sex eligibility criteria for cohort inclusion (if the study restricts enrollment)."
                },
                "studyID": {
                    "description": "The stable, unique identifier for a study that never changes, even if other study metadata changes (like the study name, short name, owner, or project). Example: STUDY_SCA",
                    "type": "string"
                }
            },
            "required": [
                "studyID"
            ],
            "title": "CohortPopulation",
            "type": "object"
        },

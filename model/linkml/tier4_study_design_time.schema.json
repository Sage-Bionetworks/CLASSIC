        "StudyDesignTime": {
            "additionalProperties": false,
            "description": "Tier 4 record \u2014 temporal coverage, study structure, and sampling design.",
            "properties": {
                "administrationContext": {
                    "description": "The physical or situational setting in which a data collection activity or assessment is administered. Describes where data collection occurs, not how, who, or what. Intended for general or summary-level reporting, not per-participant metadata.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "administrationMode": {
                    "$ref": "#/$defs/AdministrationModeEnum",
                    "description": "The manner in which a digital assessment or data collection activity is administered to participants."
                },
                "aggregationLevel": {
                    "$ref": "#/$defs/AggregationLevelEnum",
                    "description": "Specifies whether a metadata value represents individual-level data or an aggregate summary."
                },
                "appliesTo": {
                    "$ref": "#/$defs/AppliesToEnum",
                    "description": "Indicates the level of entity to which a metadata value applies (e.g., individual participant or population summary)."
                },
                "burstDesign": {
                    "description": "A summary description of the study's burst-based sampling structure (bursts, timing, follow-up cadence, and recruitment waves).",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "burstFrequency": {
                    "$ref": "#/$defs/BurstFrequencyEnum",
                    "description": "The planned frequency at which bursts occur across the study timeline."
                },
                "burstLength": {
                    "$ref": "#/$defs/BurstLengthEnum",
                    "description": "The planned duration of each burst period of intensive measurement."
                },
                "burstLengthValue": {
                    "description": "The numeric value of the planned duration of each burst period.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "collectionModality": {
                    "$ref": "#/$defs/CollectionModalityEnum",
                    "description": "The primary mode by which data were collected for a variable or assessment."
                },
                "endYear": {
                    "description": "Latest calendar year of data collection.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "enrollmentAge": {
                    "description": "The age or ages of a participant at the time of enrollment or at defined enrollment-related timepoints in a study, including single ages, age ranges, or multiple ages associated with longitudinal or staged enrollment.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "enrollmentTimepoint": {
                    "description": "A named study milestone at which enrollment occurs (e.g., baseline, re-enrollment, extension phase).",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "followUpInterval": {
                    "$ref": "#/$defs/FollowUpIntervalEnum",
                    "description": "The planned amount of time between participant follow-up assessments, visits, or measurement periods."
                },
                "followUpIntervalValue": {
                    "description": "The numeric value of the planned amount of time between participant follow-up assessments.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "followUpYear": {
                    "description": "Years since original cohort enrollment. Summarizes the amount of time elapsed since original cohort enrollment for which participant data are available. Values can be in: minYears, maxYears, years.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "followUpYearDescription": {
                    "description": "Free-text clarification (optional).",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "hasObservationTimestamp": {
                    "$ref": "#/$defs/YesNoPartialUnknownEnum",
                    "description": "Indicates whether individual observations/records include a date or timestamp of data collection."
                },
                "numberOfBursts": {
                    "description": "The number of distinct burst periods of intensive measurement scheduled per participant.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "optional_row_identifier": {
                    "$ref": "#/$defs/PersistentRowIdentifierEnum",
                    "description": "Use studyID as the anchor, plus a persistent row identifier to identify a specific file/version, etc."
                },
                "optional_row_identifier_value": {
                    "description": "Enter a unique identifier for the selection made.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "populationScope": {
                    "$ref": "#/$defs/PopulationScopeEnum",
                    "description": "Identifies the population described by the metadata (e.g., study-wide, cohort, or study arm)."
                },
                "promptFrequency": {
                    "description": "Frequency of prompts. Valid values: free text, OR Multiple, Varies, Unknown",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "promptingScheduleType": {
                    "description": "EMA schedule type. Valid values: free text, OR Multiple, Varies, Unknown",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "recruitmentWave": {
                    "$ref": "#/$defs/StudyWaveEnum",
                    "description": "Enrollment wave (baseline, follow-up, etc.). Identifies the recruitment phase or wave during which participants were enrolled in a study, reflecting distinct enrollment periods defined by study design or operational milestones."
                },
                "responseWindowMinutes": {
                    "description": "Response window (minutes). Valid values: free text, OR Multiple, Varies, Unknown.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "rollingEnrollment": {
                    "$ref": "#/$defs/RollingEnrollmentEnum",
                    "description": "Indicates whether participant enrollment occurs continuously over time rather than within a fixed recruitment window."
                },
                "seasons": {
                    "$ref": "#/$defs/SeasonsEnum",
                    "description": "Seasons during which data were collected."
                },
                "startYear": {
                    "description": "Earliest calendar year of data collection.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "studyArmID": {
                    "description": "A stable identifier for a defined study arm, group, or condition assignment used to structure participant enrollment, intervention, or comparison. Examples: ARM:CONTROL, ARM:TREATMENT_A, ARM:HIGH_RISK, ARM:CASE, ARM:COMPARATOR",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "studyComponentID": {
                    "description": "A stable identifier for a defined component of a study (e.g., wave, arm, period) used to scope metadata summaries.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "studyComponentType": {
                    "$ref": "#/$defs/StudyComponentTypeEnum",
                    "description": "The category of study subcomponent identified by studyComponentID (e.g., wave, arm, period), used to indicate what kind of study structure the component represents for scoping metadata summaries."
                },
                "studyID": {
                    "description": "The stable, unique identifier for a study that never changes, even if other study metadata changes (like the study name, short name, owner, or project). Example: STUDY_SCA",
                    "type": "string"

        "MeasuresInstruments": {
            "additionalProperties": false,
            "description": "Tier 5 record \u2014 measures, instruments, derived scores/variables, and availability summaries.",
            "properties": {
                "administrationInstructions": {
                    "description": "The instructions provided to participants describing exactly how to perform the instrument/task (verbatim or summarized).",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "administrationMode": {
                    "$ref": "#/$defs/AdministrationModeEnum",
                    "description": "The manner in which a digital assessment or data collection activity is administered to participants."
                },
                "administrationProcedure": {
                    "$ref": "#/$defs/AdministrationProcedureEnum",
                    "description": "The source of the implementation (e.g., NIH Toolbox, PEBL, PsychoPy script, custom app)."
                },
                "aggregationLevel": {
                    "$ref": "#/$defs/AggregationLevelEnum",
                    "description": "Specifies whether a metadata value represents individual-level data or an aggregate summary."
                },
                "appPlatform": {
                    "description": "App or platform used. Valid values: free text OR Multiple, Varies, Unknown.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "appliesTo": {
                    "$ref": "#/$defs/AppliesToEnum",
                    "description": "Indicates the level of entity to which a metadata value applies (e.g., individual participant or population summary)."
                },
                "constructDescription": {
                    "description": "One-sentence description of how the construct was operationalized in the study.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "dataAvailabilitySummary": {
                    "description": "An aggregate description of the amount and demographic composition of available data for a study, cohort, or variable, provided without individual-level records.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "derivationMethod": {
                    "$ref": "#/$defs/DerivationMethodEnum",
                    "description": "A high-level description of how a score was derived from raw or intermediate data."
                },
                "derivedScore": {
                    "description": "A summary description of a score derived from a measure, including how it was calculated.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "derivedVariableName": {
                    "description": "The name of a derived variable or score as it appears in the dataset or metadata record.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "derivedVariableType": {
                    "$ref": "#/$defs/DerivedVariableTypeEnum",
                    "description": "A controlled category describing the general method or type of derivation used to compute a derived variable or score (e.g., sum score, composite score, standardized score)."
                },
                "deviceType": {
                    "$ref": "#/$defs/DeviceTypeEnum",
                    "description": "The type of digital device used for data collection, applicable only when data are collected digitally."
                },
                "inputMethod": {
                    "$ref": "#/$defs/InputMethodEnum",
                    "description": "The primary method by which participant input or data capture occurs during digital data collection."
                },
                "instrumentCitation": {
                    "description": "The primary citation(s) describing the instrument/task implementation used in the study (e.g., published paper, manual, DOI).",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "instrumentID": {
                    "description": "A stable identifier used to reference a specific instrument, measure, or assessment used in a study (e.g., a validated questionnaire, cognitive task, interview protocol, or sensor-based assessment).",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "instrumentName": {
                    "description": "Name of the instrument or scale used (e.g., PHQ-9, NIH Toolbox).",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "instrumentSource": {
                    "description": "Where the instrument originated.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "instrumentVersion": {
                    "description": "Version identifier for the instrument implementation used (e.g., vendor version, protocol revision, \"v2\", \"2016 revision\").",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "isValidatedMeasure": {
                    "$ref": "#/$defs/IsValidatedMeasureEnum",
                    "description": "Indicates whether a measure or instrument used to assess a construct has been previously validated."
                },
                "manufacturerModel": {
                    "description": "Device make/model. Valid values: free text OR Multiple, Varies, Unknown.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "measureDescription": {
                    "description": "A brief description of how a measure was administered and what it was designed to assess.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "measureID": {
                    "description": "Persistent per-measure row identifier. (ex., \"MEAS_SCA_STROOP_v1\")",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "measureType": {
                    "$ref": "#/$defs/MeasureTypeEnum",
                    "description": "The general type of measure used to assess a construct."
                },
                "measuredConstruct": {
                    "$ref": "#/$defs/MeasuredConstructEnum",
                    "description": "A conceptual domain or construct that a study collected data on (e.g., depression, working memory, physical activity)."
                },
                "operatingSystem": {
                    "description": "OS and version. Valid values: free text OR Multiple, Varies, Unknown.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "optional_row_identifier": {
                    "$ref": "#/$defs/PersistentRowIdentifierEnum",
                    "description": "Use studyID as the anchor, plus a persistent row identifier to identify a specific file/version, etc."
                },
                "optional_row_identifier_value": {
                    "description": "Enter a unique identifier for the selection made.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "populationScope": {
                    "$ref": "#/$defs/PopulationScopeEnum",
                    "description": "Identifies the population described by the metadata (e.g., study-wide, cohort, or study arm)."
                },
                "preprocessingSteps": {
                    "description": "Preprocessing/cleaning applied.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "proportion": {
                    "description": "A numeric value representing the fraction of a population associated with a given category, typically expressed as a percentage or decimal.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "protocolDescription": {
                    "description": "The synID of the wiki that contains the protocol, study design and goals.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "protocolURL": {
                    "description": "Link to the protocol, manual, script, or documentation describing the instrument implementation.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "rawOrDerived": {
                    "description": "Raw vs derived data flag.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "scoreName": {
                    "description": "The human-readable name of a score derived from a measure, as used or labeled by the study.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "scoreType": {
                    "$ref": "#/$defs/ScoreTypeEnum",
                    "description": "Describes the general method or form by which a score was derived from a measure or assessment."
                },
                "sensors": {
                    "description": "Sensors enabled (GPS, accelerometer, etc.). Valid values: free text OR Multiple, Varies, Unknown.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "softwarePlatform": {
                    "$ref": "#/$defs/SoftwarePlatformEnum",
                    "description": "The software environment or application used to deliver, collect, or manage digitally collected data."
                },
                "stimulusResponseMode": {
                    "$ref": "#/$defs/StimulusResponseModeEnum",
                    "description": "How participants interacted with the instrument during administration."
                },
                "studyID": {
                    "description": "The stable, unique identifier for a study that never changes, even if other study metadata changes (like the study name, short name, owner, or project). Example: STUDY_SCA",
                    "type": "string"
                },
                "timepoint": {
                    "$ref": "#/$defs/TimepointEnum",
                    "description": "A label identifying the study timepoint or phase at which the variable value or summary applies (e.g., baseline, follow-up)."
                },
                "totalParticipants": {
                    "description": "The total number of unique participants for whom data are available within the specified study, cohort, or scope.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "unit": {
                    "$ref": "#/$defs/UnitEnum",
                    "description": "The unit of measurement associated with a variable's values or summary statistics (e.g., years, kg/m\u00b2)."
                },
                "valueRange": {
                    "description": "The observed minimum and maximum values of a continuous variable within the reported population scope.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "valueRangeMaxValue": {
                    "description": "The maximum observed value of a continuous variable within the specified population scope.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "valueRangeMinValue": {
                    "description": "The minimum observed value of a continuous variable within the specified population scope.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "variableSummary": {
                    "description": "Aggregate summary statistics describing the observed distribution and availability of a variable in a dataset, without exposing participant-level values.",
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "studyID"
            ],
            "title": "MeasuresInstruments",
            "type": "object"
        },

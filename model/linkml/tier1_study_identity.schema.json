        "StudyIdentityDiscovery": {
            "additionalProperties": false,
            "description": "Tier 1 record \u2014 study-level identity and discovery metadata. Study-scoped, so it carries only the StudyAnchored mixin (no per-row scoping block).",
            "properties": {
                "cohortID": {
                    "description": "Unique identifier for the cohort.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "cohortName": {
                    "description": "Name of cohort.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "dataSubtype": {
                    "description": "Further qualification of dataType, which may be used to indicate the state of processing of the data, aggregation of the data, or presence of metadata.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "dataType": {
                    "description": "Types of input/output data in bioinformatics pipelines.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "grantNumber": {
                    "description": "Grant number including activity code, institute code, and serial number (e.g. U01MH103392).",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "institution": {
                    "description": "Institution conducting study.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "longitudinalStudyID": {
                    "description": "Linked longitudinal study identifier.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "metadataCoverageNotes": {
                    "description": "Free-text clarification of what is included/excluded in the metadata record and why (e.g., \"some measures collected but not shareable due to licensing\").",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "metadataCoverageScope": {
                    "$ref": "#/$defs/MetadataCoverageScopeEnum",
                    "description": "Indicates whether the archived metadata describes all data collected in the study or only the data types made available for external access."
                },
                "metadataFileID": {
                    "description": "Identifies a specific metadata artifact or file (i.e, a particular \"measures.tsv\" version, etc. If the file is uploaded to Synapse, this will be the Synapse file entity ID. Examples: syn99887766 (or FILE_STUDY_SCA_measures_v2)",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "metadataType": {
                    "description": "For files of dataSubtype: metadata, a description of the type of metadata in the file.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "principalInvestigator": {
                    "description": "Name(s) of PI.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "principalInvestigatorContact": {
                    "description": "Email of (each) PI.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "principalInvestigatorRoles": {
                    "$ref": "#/$defs/PrincipalInvestigatorRolesEnum",
                    "description": "Distinguishes original vs current vs co-PI."
                },
                "studyAbstract": {
                    "description": "The short study description/abstract used to describe the study that is visible on the Portal study card.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "studyDescription": {
                    "description": "The synID of the wiki that contains the study description. Description of the study, including the types of experimental assays, model systems, types of analysis, description of cohort, associated vulnerable populations, special categories of data, rare diseases, etc. Maps to DUOplus2.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "studyID": {
                    "description": "The stable, unique identifier for a study that never changes, even if other study metadata changes (like the study name, short name, owner, or project). Example: STUDY_SCA",
                    "type": "string"
                },
                "studyKey": {
                    "description": "The short acronym for a project the study is associated with.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "studyMetadata": {
                    "description": "The wiki from the CLASSIC Portal backend that describes study metadata files.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "studyName": {
                    "description": "Name of the study.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "studyProjectIdentifier": {
                    "description": "The Synapse Project identifier (synID) with which this Study is related.",
                    "type": [
                        "string",
                        "null"
                    ]
                }
            },
            "required": [
                "studyID"
            ],
            "title": "StudyIdentityDiscovery",
            "type": "object"
        },

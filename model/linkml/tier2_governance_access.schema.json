        "GovernanceAccessProvenance": {
            "additionalProperties": false,
            "description": "Tier 2 record \u2014 governance, access policy, and provenance metadata.",
            "properties": {
                "accessContact": {
                    "description": "Point of contact (team, email alias, or role) for access questions.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "accessProcedure": {
                    "description": "Brief description of the steps required to request and obtain access to the dataset.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "accessRequestURL": {
                    "description": "URL to the access request page/portal or repository instructions for obtaining access.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "accessRequirements": {
                    "$ref": "#/$defs/AccessRequirementsEnum",
                    "description": "Checklist of materials required for access (e.g., DUA, IRB letter, training)."
                },
                "accessRestrictions": {
                    "$ref": "#/$defs/AccessRestrictionsEnum",
                    "description": "Access level (ex., open, controlled, embargoed)."
                },
                "accessReviewBody": {
                    "$ref": "#/$defs/AccessReviewBodyEnum",
                    "description": "The entity that reviews/approves access requests (e.g., DAC, IRB, sponsor)."
                },
                "aggregationLevel": {
                    "$ref": "#/$defs/AggregationLevelEnum",
                    "description": "Specifies whether a metadata value represents individual-level data or an aggregate summary."
                },
                "appliesTo": {
                    "$ref": "#/$defs/AppliesToEnum",
                    "description": "Indicates the level of entity to which a metadata value applies (e.g., individual participant or population summary)."
                },
                "cohortID": {
                    "description": "Unique identifier for the cohort.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "consentType": {
                    "$ref": "#/$defs/ConsentTypeEnum",
                    "description": "Consent type (broad, tiered, etc.)."
                },
                "dataLocation": {
                    "$ref": "#/$defs/DataLocationEnum",
                    "description": "Where the dataset is hosted or distributed (e.g., Synapse project, NIMH/NDAR collection, dbGaP)."
                },
                "dataUseConditions": {
                    "description": "Data use conditions.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "deidentificationMethod": {
                    "$ref": "#/$defs/DeidentificationMethodEnum",
                    "description": "De-ID method applied."
                },
                "externallyRequestable": {
                    "$ref": "#/$defs/ExternallyRequestableEnum",
                    "description": "Availability indicator to request the data."
                },
                "irbApprovalDescription": {
                    "description": "Free-text description providing additional context about IRB approval, exemption, or oversight.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "irbApprovalNumber": {
                    "description": "The identifier assigned by the IRB for an approved or reviewed study, if applicable.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "irbExemptionType": {
                    "$ref": "#/$defs/IrbExemptionTypeEnum",
                    "description": "The regulatory exemption category under which the study was determined to be exempt from IRB review."
                },
                "irbInstitution": {
                    "description": "The institution or ethics committee responsible for IRB review or determination.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "irbScope": {
                    "$ref": "#/$defs/IrbScopeEnum",
                    "description": "Scope of IRB in relation to the study."
                },
                "irbStatus": {
                    "$ref": "#/$defs/IrbStatusEnum",
                    "description": "The regulatory determination of IRB oversight for the study."
                },
                "optional_row_identifier": {
                    "$ref": "#/$defs/PersistentRowIdentifierEnum",
                    "description": "Use studyID as the anchor, plus a persistent row identifier to identify a specific file/version, etc."
                },
                "optional_row_identifier_value": {
                    "description": "Enter a unique identifier for the selection made.",
                    "type": [
                        "string",
                        "null"
                    ]
                },
                "populationScope": {
                    "$ref": "#/$defs/PopulationScopeEnum",
                    "description": "Identifies the population described by the metadata (e.g., study-wide, cohort, or study arm)."
                },
                "studyID": {
                    "description": "The stable, unique identifier for a study that never changes, even if other study metadata changes (like the study name, short name, owner, or project). Example: STUDY_SCA",
                    "type": "string"
                }
            },
            "required": [
                "studyID"
            ],
            "title": "GovernanceAccessProvenance",
            "type": "object"
        },
